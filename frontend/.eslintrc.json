{
    "env": {
        "browser": true,
        "es2021": true,
        "es6": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended",
        "plugin:react-hooks/recommended",
        "standard-react",
        "standard",
        "plugin:prettier/recommended",
        "plugin:jest/all",
        "prettier"
    ],
    "parser": "babel-eslint",
    // "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true,
            "modules": true
        },
        "ecmaVersion": 12,
        "sourceType": "module"
    },
    "globals": {
        "React": false,
        "ReactDOM": false,
        "moment": false,
        "$": false,
        "_": false,
        "__WebpackModuleApi": true
    },
    "plugins": [
        "react",
        "react-hooks",
        "prettier"
    ],
    "overrides": [
        {
            "files": [
                "*.ts",
                "*.tsx"
            ],
            "extends": [
                "...eslintExtends",
                "plugin:@typescript-eslint/recommended",
            ],
            "plugins": [
                "...eslintPlugins",
                "@typescript-eslint"
            ]
            // "...commonConfig"
        }
    ],
    "rules": {
        "prettier/prettier": "error",
        "space-before-function-paren": 0,
        "semi": 2,
        "camelcase": "off",
        "react/prop-types": 0,
        "react/no-unknown-property": 0,
        "react/no-unescaped-entities": [
            "error",
            {
                "forbid": [
                    {
                        "char": "`'`",
                        "alternatives": [
                            "`&#39`"
                        ]
                    }
                ]
            }
        ],
        "globals": {
            "__WebpackModuleApi": true
        }
    },
    "settings": {
        "react": {
            "version": "17.0"
        }
    }
}